<!DOCTYPE html>
<html id = "background" lang = "en">
	<head>
		<meta charset="UTF-8">
  <link rel="stylesheet" href="/stylesheets/signup.css">
		<link rel = "stylesheet" href = "/stylesheets/style.css">
		<title>GSP-Sign Up</title>
	</head>
	<body>
		<header>
			<nav class="navbar">
				<div class="nav-left">
					<div class="nav-logo">GSP</div>
					<h1 class="nav-title">Sign Up</h1>
				</div>
			</nav>
		</header>
		<main>
		<div class = "signup-container">
			<form class="signup-form">
			  <div class="form-row">
				<div class="form-column">
				  <label for="first-name">First Name</label>
				  <input type="text" id="first-name" name="First Name" placeholder="Dani">
				</div>
				<div class="form-column">
				  <label for="last-name">Last Name</label>
				  <input type="text" id="last-name" name="Last Name" placeholder="El Halabi">
				</div>
			  </div>

			  <div class="form-row">
				<div class="form-column">
				  <label for="dob">Date of Birth</label>
				  <input type="date" id="dob" name="Date of Birth">
				</div>
				<div class="form-column">
				  <label for="pob">Place of Birth</label>
				  <input type="text" id="pob" name="Place of Birth" placeholder = "Bchamoun">
				</div>
			  </div>

			  <div class="form-row">
				<div class="form-column">
				  <label for="email">Email</label>
				  <input type="email" id="email" name="Email" placeholder="...@gmail.com">
				</div>
				<div class="form-column">
				  <label for="phone">Phone Number</label>
				  <input type="tel" id="phone" name="Phone Number" placeholder="+961 70 123 456">
				</div>
			  </div>

			  <div class="form-row">
				<div class="form-column">
				  <label for="username">Username</label>
				  <input type="text" id="username" name="username" placeholder = "T-Rex123">
				</div>
				<div class="form-column">
				  <label for="password">Password</label>
				  <input type="password" id="password" name="password" placeholder = "Password...">
				</div>
			  </div>
			  <div>
			  <input type = "checkbox" name = "checkbox">
			  <label for = "T&C">Agree that you have written all the right information</label>
			  </div>
			  <div>
			  <button id = "login-btn" type = "submit">Sign Up</button>
			  </div>
			</form>
		</div>
		</main>
		<footer style="text-align:center; padding:20px; margin-top:60px; color:#777;">
			<p>© 2025 Government Service Portal | All Rights Reserved</p>
		</footer>
		<script src="/javascripts/universal.js"></script>
		<script src="/javascripts/signup.js"></script>
	</body>
</html>
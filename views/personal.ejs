			<div class="form-column">
			  <label for="email">Email</label>
			  <input type="email" id="email" value="dani.elhalabi@std.balamand.edu.lb">
			</div>
			<div class="form-column">
			  <label for="phone">Phone Number</label>
			  <input type="text" id="phone" value="+961 03 072 042">
			</div>
		  </div>

		  <button type="submit">Update Info</button>
		</form>
	  </div>

			<div class="form-column">
			  <label for="dob">Date of Birth</label>
			  <input type="date" id="dob" value="2002-03-14">
			</div>
			<div class="form-column">
			  <label for="pob">Place of Birth</label>
			  <input type="text" id="pob" value="Bchamoun">
